# Copy to .env (or set in your host's env config) before running.
# Shared password for you + your partner. Anyone who has it can sign in.
SUMMIT_PASSWORD=change-me

# Random secret used to sign session cookies. Generate with: python -c "import secrets;print(secrets.token_hex(32))"
SUMMIT_SECRET=change-me-to-a-long-random-string

# Branding shown across the app, landing page, quotes, and invoices
SUMMIT_BUSINESS_NAME=Summit Shine
SUMMIT_TAGLINE=Naturally spotless.
SUMMIT_BUSINESS_EMAIL=hello@summitshine.com
SUMMIT_BUSINESS_PHONE=
SUMMIT_SERVICE_AREA=

# Currency symbol shown on quotes/invoices
SUMMIT_CURRENCY=$

# Tax rate applied to quotes/invoices (decimal, e.g. 0.10 for 10%)
SUMMIT_TAX_RATE=0

# Names that show up in the "assigned to" dropdown on jobs
SUMMIT_TEAM=Aidan,Partner

# Where to store the SQLite database file (use a persistent disk path in production)
SUMMIT_DB=summit_shine.db
